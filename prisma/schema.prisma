generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                    @id @default(cuid())
  name                      String
  email                     String                    @unique
  emailVerified             Boolean                   @default(false)
  image                     String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  officialStudentVerifiedAt DateTime?
  curseducaMemberId         Int?
  curseducaMemberSlug       String?
  curseducaMemberUuid       String?
  curseducaSyncNeedsRetry   Boolean                   @default(false)
  accounts                  Account[]
  productFeedbacks          ProductFeedback[]
  sessions                  Session[]
  jornadaTaskProgress       UserJornadaTaskProgress[]
  onboardingProgress        UserOnboardingProgress[]
  profile                   UserProfile?
  streak                    UserStreak?
  streakBadges              UserStreakBadge[]
  streakDailyActivities     UserStreakDailyActivity[]
  jobReports                JobReport[]
  mgmReferralCode           String?                   @unique // MGM: gerado lazy na 1ª visita a /indique-e-ganhe
  mgmRankingOptIn           Boolean                   @default(true) // MGM Fase 1: aparece no leaderboard público (opt-out vira "Anônimo")
  mgmReferralsMade          MgmReferral[]             @relation("ReferrerUser")
  mgmRedemptions            MgmRedemption[]
}

model ProductFeedback {
  id               String                  @id @default(cuid())
  userId           String
  category         ProductFeedbackCategory
  status           ProductFeedbackStatus   @default(RECEIVED)
  title            String
  description      String
  expectedBehavior String?
  pagePath         String?
  impact           String?
  contactEmail     String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, category])
}

model UserOnboardingProgress {
  id              String           @id @default(cuid())
  userId          String
  tutorialKey     String
  tutorialVersion Int
  status          OnboardingStatus @default(NOT_STARTED)
  currentStep     Int              @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  skippedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tutorialKey, tutorialVersion])
  @@index([userId])
  @@index([tutorialKey, tutorialVersion])
}

model UserJornadaTaskProgress {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
}

model UserStreak {
  id                  String    @id @default(cuid())
  userId              String    @unique
  currentStreakDays   Int       @default(0)
  longestStreakDays   Int       @default(0)
  streakPoints        Int       @default(0)
  lastQualifiedDay    String?
  lastTaskCompletedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentStreakDays])
}

model UserStreakDailyActivity {
  id          String   @id @default(cuid())
  userId      String
  dayKey      String
  completedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([userId])
  @@index([dayKey])
}

model StreakBadge {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  description  String
  icon         String?
  requiredDays Int               @unique
  sortOrder    Int               @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  users        UserStreakBadge[]

  @@index([sortOrder])
  @@index([isActive])
}

model UserStreakBadge {
  id        String      @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  badge     StreakBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@index([awardedAt])
}

model UserProfile {
  id                  String           @id @default(cuid())
  userId              String           @unique
  fullName            String?
  linkedinUrl         String?
  githubUrl           String?
  city                String?
  professionalSummary String?
  experiences         String[]         @default([])
  knownTechnologies   String[]         @default([])
  certifications      String[]         @default([])
  languages           String[]         @default([])
  resumeFileName      String?
  resumeSyncStatus    ResumeSyncStatus @default(NOT_UPLOADED)
  resumeUploadedAt    DateTime?
  mgmShippingAddress  Json? // MGM Fase 1: endereço pré-preenchido p/ resgates físicos
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  softSkills          String[]         @default([])
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects            UserProject[]
}

model UserProject {
  id               String      @id @default(cuid())
  userProfileId    String
  title            String
  shortDescription String?
  technologies     String[]    @default([])
  deployUrl        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  userProfile      UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@index([userProfileId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Job {
  id                 String      @id @default(cuid())
  title              String
  companyName        String
  level              JobLevel    @default(OUTRO)
  stack              String[]
  location           String?
  isRemote           Boolean     @default(false)
  publishedAt        DateTime?
  source             JobSource
  sourceUrl          String
  externalId         String?
  fingerprint        String      @unique
  lastSeenAt         DateTime    @default(now())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  isActive           Boolean     @default(true)
  inactivatedAt      DateTime?
  inactivationReason String?
  reports            JobReport[]

  @@unique([source, externalId])
  @@index([source])
  @@index([level])
  @@index([isActive, lastSeenAt])
  @@index([publishedAt])
  @@index([companyName])
}

model JobIngestionLog {
  id            String             @id @default(cuid())
  source        JobSource
  startedAt     DateTime
  finishedAt    DateTime?
  fetchedCount  Int                @default(0)
  insertedCount Int                @default(0)
  updatedCount  Int                @default(0)
  failedCount   Int                @default(0)
  status        JobIngestionStatus
  errorSummary  String?
  createdAt     DateTime           @default(now())
}

// ─────────────────────────────────────────────────────────────
// MGM (Member-Get-Member) — Fase 0 + Fase 1. Ver docs/member-get-member/spec-fase-0-rota-scudo.md (v0.4).
// RLS/GRANT das tabelas abaixo: migrations hand-authored (default privileges revogados).
// ─────────────────────────────────────────────────────────────

enum MgmReferralStatus {
  pending // dentro da garantia (default 15d, env MGM_GUARANTEE_DAYS)
  valid // garantia passou, conta pra ranking e resgate
  invalid // falhou validação (motivo em invalidReason)
  reverted // reembolsado pós-garantia, ponto debitado
}

enum PaymentGateway {
  hubla
  asaas
  stripe
  other
}

enum MgmRewardType {
  PHYSICAL // camiseta, livro — ops envia (UserProfile.mgmShippingAddress)
  DIGITAL_DISCOUNT // % off renovação — ops gera cupom manual na Hubla
  DIGITAL_VOUCHER // 1 ano grátis — ops aplica via Curseduca ou cupom 100%
}

enum MgmRedemptionStatus {
  requested // aluno pediu
  approved // ops aprovou (físico em produção; digital pode ir direto p/ delivered)
  delivered // entregue (cupom gerado / item enviado)
  rejected // ops rejeitou (estorna pontos)
  cancelled // aluno cancelou antes de ops mexer (estorna pontos)
}

model MgmReferral {
  id               String            @id @default(cuid())
  referrerUserId   String // FK pra User (aluno indicador), resolvido via mgmReferralCode
  referralCodeUsed String // o ?ref= que veio na URL (denormalizado pra auditoria)
  referredEmail    String // e-mail do amigo que comprou (do payload do gateway)
  referredPhone    String?
  referredName     String?
  saleAmount       Decimal           @db.Decimal(10, 2)
  gateway          PaymentGateway    @default(hubla) // MGM Fase 1: multi-gateway
  gatewayOrderId   String // ID do pedido no gateway (renomeado de hublaOrderId)
  pointsBase       Int // 100 (env MGM_POINTS_BASE)
  pointsMultiplier Decimal           @db.Decimal(3, 1) // boost da temporada (1.5x-3x); 1.0 fora
  pointsEarned     Int // pointsBase × pointsMultiplier (denormalizado p/ ranking rápido)
  status           MgmReferralStatus @default(pending)
  invalidReason    String? // self_referral | duplicate | existing_student | disposable_domain | manual_disqualify
  guaranteeUntil   DateTime // signedUpAt + MGM_GUARANTEE_DAYS (default 15d)
  signedUpAt       DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  referrerUser     User              @relation("ReferrerUser", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@unique([gateway, gatewayOrderId]) // idempotência multi-gateway
  @@index([referrerUserId, status])
  @@index([referredEmail])
  @@index([referralCodeUsed])
}

model MgmClick {
  id            String   @id @default(cuid())
  referralCode  String
  referredEmail String? // se a rota intermediária /i/[code] capturar
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([referralCode])
  @@index([referredEmail])
  @@index([createdAt])
}

model MgmReward {
  id           String          @id @default(cuid())
  slug         String          @unique
  name         String
  description  String?
  costPoints   Int
  type         MgmRewardType
  rewardFamily String // "merch-camiseta" | "merch-livro" | "renovacao" — exclusividade por aluno
  metadata     Json? // { discountPercent: 30, durationMonths: 12, sku: "..." }
  active       Boolean         @default(true)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  redemptions  MgmRedemption[]

  @@index([active, sortOrder])
  @@index([rewardFamily])
}

model MgmRedemption {
  id             String              @id @default(cuid())
  userId         String
  rewardId       String
  rewardFamily   String // denormalizado p/ índice de exclusividade O(1)
  costSnapshot   Int // costPoints no momento do resgate (auditoria)
  status         MgmRedemptionStatus @default(requested)
  shippingInfo   Json? // { name, phone, address, city, state, zip } se PHYSICAL
  deliveryInfo   Json? // { couponCode, tracking, deliveredVia }
  rejectedReason String?
  requestedAt    DateTime            @default(now())
  approvedAt     DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward         MgmReward           @relation(fields: [rewardId], references: [id])

  @@index([userId, status])
  @@index([userId, rewardFamily, status]) // check de exclusividade por família
  @@index([status, requestedAt]) // fila do admin
}

model JobReport {
  id            String          @id @default(cuid())
  userId        String
  jobId         String
  reason        JobReportReason
  status        JobReportStatus @default(PENDING)
  reviewAfterAt DateTime
  reviewedAt    DateTime?
  inactivatedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([status, reviewAfterAt])
  @@index([jobId, status, reviewAfterAt])
  @@index([userId, createdAt])
}

