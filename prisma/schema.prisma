generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobLevel {
  ESTAGIO
  JUNIOR
  PLENO
  SENIOR
  OUTRO
}

enum JobSource {
  LINKEDIN
  GUPY
  COMPANY_SITE
  OTHER
}

enum JobIngestionStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum ResumeSyncStatus {
  NOT_UPLOADED
  UPLOADED
  PROCESSING
  READY
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ProductFeedbackCategory {
  BUG
  UX
  FEATURE
  CONTENT
  OTHER
}

enum ProductFeedbackStatus {
  RECEIVED
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  DONE
  DECLINED
}

model User {
  id                        String                    @id @default(cuid())
  name                      String
  email                     String                    @unique
  emailVerified             Boolean                   @default(false)
  officialStudentVerifiedAt DateTime?
  curseducaMemberId         Int?
  curseducaMemberSlug       String?
  curseducaMemberUuid       String?
  curseducaSyncNeedsRetry   Boolean                   @default(false)
  image                     String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  profile                   UserProfile?
  sessions                  Session[]
  accounts                  Account[]
  jornadaTaskProgress       UserJornadaTaskProgress[]
  streak                    UserStreak?
  streakBadges              UserStreakBadge[]
  streakDailyActivities     UserStreakDailyActivity[]
  onboardingProgress        UserOnboardingProgress[]
  productFeedbacks          ProductFeedback[]
}

model ProductFeedback {
  id               String                  @id @default(cuid())
  userId           String
  category         ProductFeedbackCategory
  status           ProductFeedbackStatus   @default(RECEIVED)
  title            String
  description      String
  expectedBehavior String?
  pagePath         String?
  impact           String?
  contactEmail     String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, category])
}

model UserOnboardingProgress {
  id              String           @id @default(cuid())
  userId          String
  tutorialKey     String
  tutorialVersion Int
  status          OnboardingStatus @default(NOT_STARTED)
  currentStep     Int              @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  skippedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tutorialKey, tutorialVersion])
  @@index([userId])
  @@index([tutorialKey, tutorialVersion])
}

model UserJornadaTaskProgress {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
}

model UserStreak {
  id                  String   @id @default(cuid())
  userId              String   @unique
  currentStreakDays   Int      @default(0)
  longestStreakDays   Int      @default(0)
  streakPoints        Int      @default(0)
  lastQualifiedDay    String?
  lastTaskCompletedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentStreakDays])
}

model UserStreakDailyActivity {
  id          String   @id @default(cuid())
  userId      String
  dayKey      String
  completedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([userId])
  @@index([dayKey])
}

model StreakBadge {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  description  String
  icon         String?
  requiredDays Int               @unique
  sortOrder    Int               @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  users        UserStreakBadge[]

  @@index([sortOrder])
  @@index([isActive])
}

model UserStreakBadge {
  id        String     @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     StreakBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@index([awardedAt])
}

model UserProfile {
  id                  String           @id @default(cuid())
  userId              String           @unique
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName            String?
  linkedinUrl         String?
  githubUrl           String?
  city                String?
  professionalSummary String?
  experiences         String[]         @default([])
  knownTechnologies   String[]         @default([])
  softSkills          String[]         @default([])
  certifications      String[]         @default([])
  languages           String[]         @default([])
  projects            UserProject[]
  resumeFileName      String?
  resumeSyncStatus    ResumeSyncStatus @default(NOT_UPLOADED)
  resumeUploadedAt    DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model UserProject {
  id               String      @id @default(cuid())
  userProfileId    String
  userProfile      UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  title            String
  shortDescription String?
  technologies     String[]    @default([])
  deployUrl        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([userProfileId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Job {
  id          String    @id @default(cuid())
  title       String
  companyName String
  level       JobLevel  @default(OUTRO)
  stack       String[]
  location    String?
  isRemote    Boolean   @default(false)
  isActive    Boolean   @default(true)
  publishedAt DateTime?
  source      JobSource
  sourceUrl   String
  externalId  String?
  fingerprint String    @unique
  lastSeenAt  DateTime  @default(now())
  inactivatedAt DateTime?
  inactivationReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([source, externalId])
  @@index([source])
  @@index([level])
  @@index([isActive, lastSeenAt])
  @@index([publishedAt])
  @@index([companyName])
}

model JobIngestionLog {
  id            String             @id @default(cuid())
  source        JobSource
  startedAt     DateTime
  finishedAt    DateTime?
  fetchedCount  Int                @default(0)
  insertedCount Int                @default(0)
  updatedCount  Int                @default(0)
  failedCount   Int                @default(0)
  status        JobIngestionStatus
  errorSummary  String?
  createdAt     DateTime           @default(now())
}
