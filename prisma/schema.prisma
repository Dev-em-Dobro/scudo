enum JobLevel {
  ESTAGIO
  JUNIOR
  PLENO
  SENIOR
  OUTRO
}

enum JobSource {
  LINKEDIN
  GUPY
  COMPANY_SITE
  OTHER
}

enum JobReportReason {
  EXPIRED
  UNAVAILABLE
  CANCELLED
}

enum JobReportStatus {
  PENDING
  INACTIVATED
  REVIEWED
}

enum JobIngestionStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum ResumeSyncStatus {
  NOT_UPLOADED
  UPLOADED
  PROCESSING
  READY
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ProductFeedbackCategory {
  BUG
  UX
  FEATURE
  CONTENT
  OTHER
}

enum ProductFeedbackStatus {
  RECEIVED
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  DONE
  DECLINED
}
