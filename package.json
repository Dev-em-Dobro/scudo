{
    "name": "scudo",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --webpack",
        "dev:local": "DATABASE_URL=$LOCAL_DATABASE_URL next dev --webpack",
        "dev:turbo": "next dev --turbopack",
        "dev:local:turbo": "DATABASE_URL=$LOCAL_DATABASE_URL next dev --turbopack",
        "prebuild": "prisma generate",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "db:local:up": "docker compose up -d postgres",
        "db:local:down": "docker compose down",
        "db:local:logs": "docker compose logs -f postgres",
        "curseduca:export-lessons": "node scripts/export-curseduca-lessons.mjs",
        "dobro-api:fetch-tree": "node --env-file=.env scripts/dobro-api/fetch-course-tree.mjs",
        "dobro-api:list-courses": "node scripts/dobro-api/fetch-course-tree.mjs --list",
        "db:export-user-seed": "node --env-file=.env scripts/db/export-user-seed.mjs",
        "db:seed-local-user": "DATABASE_URL=$LOCAL_DATABASE_URL node --env-file=.env prisma/seed.mjs",
        "jornada:bootstrap-catalog": "node scripts/jornada/bootstrap-catalog-from-code.mjs",
        "jornada:bootstrap-catalog:local": "CATALOG_DATABASE_URL=$LOCAL_DATABASE_URL node scripts/jornada/bootstrap-catalog-from-code.mjs",
        "jornada:reconcile-catalog": "node --env-file=.env scripts/jornada/reconcile-curseduca-catalog.mjs",
        "jornada:propose-exercise-mappings": "node --env-file=.env scripts/jornada/propose-exercise-mappings.mjs",
        "jornada:propose-lesson-mappings": "node --env-file=.env scripts/jornada/propose-lesson-mappings.mjs",
        "jornada:apply-lesson-mappings": "node scripts/jornada/apply-lesson-mapping-proposals.mjs",
        "jornada:smoke-test:local": "DATABASE_URL=$LOCAL_DATABASE_URL node scripts/jornada/smoke-test-local.mjs",
        "jornada:backfill-resume:local": "DATABASE_URL=$LOCAL_DATABASE_URL npx tsx scripts/jornada/backfill-generated-resume.mjs",
        "jornada:seed-user-progress:local": "DATABASE_URL=$LOCAL_DATABASE_URL node --env-file=.env scripts/jornada/seed-user-progress.mjs",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:migrate:local": "DATABASE_URL=$LOCAL_DATABASE_URL prisma migrate deploy",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "prisma:studio:local": "DATABASE_URL=$LOCAL_DATABASE_URL prisma studio"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@prisma/adapter-pg": "^6.16.3",
        "@prisma/client": "^6.16.3",
        "better-auth": "^1.3.10",
        "driver.js": "^1.4.0",
        "mammoth": "^1.12.0",
        "next": "16.1.6",
        "nodemailer": "^8.0.2",
        "pdf-lib": "^1.17.1",
        "pdf-parse": "^2.4.5",
        "pg": "^8.18.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.62.0",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@better-auth/cli": "^1.3.10",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/nodemailer": "^7.0.11",
        "@types/pg": "^8.16.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "prisma": "^6.16.3",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
